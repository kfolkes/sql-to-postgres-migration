# DAB connection strings - DO NOT COMMIT REAL VALUES
# Copy this file to .env and fill in your connection strings

# SQL Server (source)
SQLSERVER_CONN=Server=localhost;Database=WideWorldImporters;Trusted_Connection=True;TrustServerCertificate=True;

# PostgreSQL (target)
POSTGRES_CONN=Host=localhost;Database=wide_world_importers;Username=wwi_user;Password=CHANGE_ME;SSL Mode=Prefer;

# Fabric SQL DB (optional)
FABRIC_CONN=Server=your-server.database.fabric.microsoft.com;Database=WideWorldImporters;Authentication=Active Directory Default;
