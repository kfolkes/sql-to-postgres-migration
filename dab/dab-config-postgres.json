{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "postgresql",
    "connection-string": "@env('POSTGRES_CONN')",
    "options": {}
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp"
    },
    "host": {
      "cors": {
        "origins": ["http://localhost:3000"],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "Simulator"
      },
      "mode": "development"
    }
  },
  "entities": {
    "StockItems": {
      "source": { "object": "warehouse.stock_items", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "StockItem", "plural": "StockItems" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "*" }] }],
      "description": "Products in WideWorldImporters warehouse inventory (migrated to PostgreSQL)"
    },
    "Suppliers": {
      "source": { "object": "purchasing.suppliers", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Supplier", "plural": "Suppliers" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Supplier organizations (migrated to PostgreSQL)"
    },
    "Customers": {
      "source": { "object": "sales.customers", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Customer", "plural": "Customers" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Customer accounts (migrated to PostgreSQL)"
    },
    "Orders": {
      "source": { "object": "sales.orders", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Order", "plural": "Orders" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Sales orders (migrated to PostgreSQL)"
    },
    "PurchaseOrders": {
      "source": { "object": "purchasing.purchase_orders", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "PurchaseOrder", "plural": "PurchaseOrders" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Purchase orders (migrated to PostgreSQL)"
    }
  }
}
