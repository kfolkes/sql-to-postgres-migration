{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('SQLSERVER_CONN')",
    "options": {
      "set-session-context": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp"
    },
    "host": {
      "cors": {
        "origins": ["http://localhost:3000"],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "Simulator"
      },
      "mode": "development"
    }
  },
  "entities": {
    "StockItems": {
      "source": { "object": "Warehouse.StockItems", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "StockItem", "plural": "StockItems" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "*" }] }],
      "description": "Products in WideWorldImporters warehouse inventory"
    },
    "Suppliers": {
      "source": { "object": "Purchasing.Suppliers", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Supplier", "plural": "Suppliers" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Supplier organizations providing products"
    },
    "Customers": {
      "source": { "object": "Sales.Customers", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Customer", "plural": "Customers" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Customer accounts for WideWorldImporters"
    },
    "Orders": {
      "source": { "object": "Sales.Orders", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "Order", "plural": "Orders" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Sales orders placed by customers"
    },
    "PurchaseOrders": {
      "source": { "object": "Purchasing.PurchaseOrders", "type": "table" },
      "graphql": { "enabled": true, "type": { "singular": "PurchaseOrder", "plural": "PurchaseOrders" } },
      "rest": { "enabled": true },
      "permissions": [{ "role": "anonymous", "actions": [{ "action": "read" }] }],
      "description": "Purchase orders sent to suppliers"
    }
  }
}
