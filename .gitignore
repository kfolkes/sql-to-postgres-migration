tests/performance/results/*.json
!tests/performance/results/README.md

# Security scan results (sensitive)
security/sec-check-results/*.json

# SSMS execution plans (large binary)
benchmarks/ssms-plans/*.sqlplan

# pgLoader state
*.pgloader
