# Dependencies
node_modules/
.env
*.env.local

# DAB
dab/.env

# Local database data (cached backups, Docker volumes)
data/

# Build outputs
bin/
obj/
dist/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
